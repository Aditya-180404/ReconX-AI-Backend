# ── Python / Backend ──────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.spec
venv/
.venv/
env/
.env          # real secrets — never commit
*.log

# ── Node / Frontend ───────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.local

# ── Database ──────────────────────────────────────────
*.sql.bak

# ── Reports & Uploads (generated content) ─────────────
reports/*.pdf
uploads/*
!uploads/.gitkeep
!reports/.gitkeep

# ── IDE / OS ──────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
