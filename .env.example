# ─────────────────────────────────────────────────────
# ReconX AI — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit the real .env to source control.
# ─────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── JWT ───────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_KEY

# ── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=reconx_db
DB_USER=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD

# ── AI Engine ─────────────────────────────────────────
# OpenAI key  →  https://platform.openai.com
# Gemini key  →  set OPENAI_BASE_URL to a Gemini-compatible base URL
OPENAI_API_KEY=sk-YOUR_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Reports ───────────────────────────────────────────
REPORTS_DIR=../reports
UPLOADS_DIR=../uploads
